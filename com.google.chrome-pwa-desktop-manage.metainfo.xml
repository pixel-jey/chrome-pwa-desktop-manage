        <p>Initial release.</p>
      </description>
    </release>
    <release version="1.0.0" date="2025-12-29">
      <description>
        <p>Initial release.</p>
      </description>
    </release>
  </releases>

  <metadata_license>CC0-1.0</metadata_license>
