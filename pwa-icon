#!/bin/bash

# 1. Get input argument (App ID)
APP_ID=$1

# 2. Check if ID is provided
if [ -z "$APP_ID" ]; then
    echo "Usage: pwa-icon <APP_ID>"
    exit 1
fi

echo "Searching for native icon for App ID: $APP_ID..."

# 3. Locate the directory for the given ID
# Searching within ~/.config and suppressing permission errors
TARGET_DIR=$(find ~/.config -type d -name "$APP_ID" | head -n 1)

# 4. Check if directory exists
if [ -z "$TARGET_DIR" ]; then
    echo "ERROR: Directory for ID '$APP_ID' not found in ~/.config"
    exit 1
fi

# 5. Search for the 64-pixel icon file within that directory
ICON_FILE=$(find "$TARGET_DIR" -type f -name "*64.png" | head -n 1)

# 6. Check if the file exists and perform the copy
if [ -f "$ICON_FILE" ]; then
    # Copy to current directory
    cp "$ICON_FILE" ./64.png
    
    echo "Success: Native icon found and copied."
    
    # 7. Execute file command to display information and dimensions
    echo "Current file info:"
    file 64.png
else
    echo "ERROR: Could not find any '*64.png' file inside the App directory."
    exit 1
fi

